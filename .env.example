# ══════════════════════════════════════════════════════════════
#  جامعة v4.0 — ملف متغيرات البيئة
# ══════════════════════════════════════════════════════════════
#  انسخ هذا الملف بإسم ".env" وعدّل القيم

# رمز البوت من @BotFather — مطلوب
BOT_TOKEN=123456789:ABCdefGhIJKlmnoPQRstuvwXYZ

# معرف المطور من @userinfobot — مطلوب
DEVELOPER_ID=123456789

# المنفذ للسيرفر (اختياري - 3000 افتراضياً)
PORT=3000

# رابط Render الخارجي لوضع Webhook (اختياري - اتركه فارغاً للـ Polling)
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

# مسار ملف قاعدة البيانات (اختياري - data.json افتراضياً)
# DATA_FILE=/app/data.json
